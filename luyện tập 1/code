#include <iostream>
using namespace std;

int timMax(int arr[], int n) {
    int max = arr[0];
    for (int i = 1; i < n; i++)
        if (arr[i] > max)
            max = arr[i];
    return max;
}

int main() {
    int arr[] = {3, 7, 1, 9, 4, 6};
    int n = 6;
    cout << "Mang: ";
    for (int i = 0; i < n; i++)
        cout << arr[i] << " ";
    cout << "\nGia tri lon nhat: " << timMax(arr, n) << endl;
    return 0;
}
